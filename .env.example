NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# BOLD Payment Link Robot (Railway)
BOLD_ROBOT_URL=https://morfx-production-9b7a.up.railway.app

# ============================================================================
# Phase 44: CRM Bots
# ============================================================================

# Global kill-switch for CRM bots (crm-reader + crm-writer).
# Set to 'false' to return HTTP 503 for all /api/v1/crm-bots/* requests.
# Any other value (or unset) = bots enabled.
# CRITICAL: env var is read PER-REQUEST, not at module load — flipping this
# takes effect within ~5 seconds without redeploy in DEV. In Vercel prod,
# requires a redeploy (or warm-lambda expiry) — see Plan 09 Task 5 step 8 for
# the kill-switch verification procedure.
CRM_BOT_ENABLED=true

# Per-workspace rate limit for crm-bot module (reader + writer share budget).
# Default: 50 calls/min. Acknowledged as a runaway-detection heuristic,
# NOT a hard enforcement ceiling (in-memory limiter does not survive
# lambda cold starts — see 44-RESEARCH.md Pitfall 1).
CRM_BOT_RATE_LIMIT_PER_MIN=50

# Resend API key for transactional email alerts (runaway loops, approaching limit).
# Get from: https://resend.com/api-keys
# Leaving unset disables email delivery — alert functions fail-silent (console.error).
RESEND_API_KEY=

# FROM address for CRM bot alerts. Must be a DKIM/SPF-verified Resend sending
# domain in production (e.g. 'MorfX Alerts <alerts@morfx.app>'). Leave blank in
# dev to use the Resend sandbox domain 'onboarding@resend.dev' which works
# out-of-the-box without any domain verification.
# BLOCKER 5 fix (revision 2026-04-18): previously hardcoded alerts@morfx.app
# would silently fail if morfx.app wasn't verified — now parameterized.
CRM_BOT_ALERT_FROM=
