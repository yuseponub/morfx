# Copy to .env.test (gitignored) and fill with real values for integration tests.
# These tests hit REAL Supabase tables; never use production workspace/stage ids.
#
# Usage (vitest lee .env.test automaticamente via dotenv en vitest.config.ts
# si se configura, o desde el shell con `export $(cat .env.test | xargs)`
# antes de `npm test`).
#
# Si estas env vars NO estan set, los tests de integration (orders-cas,
# order-stage-history-rls) SKIP via describe.skipIf(!envReady) — no fail,
# no pass silencioso.

# --- Supabase admin (required) ---
# createClient(SUPABASE_URL, SERVICE_ROLE_KEY) bypasea RLS; los tests validan
# que los triggers plpgsql (append-only) bloquean incluso con service_role.
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt-from-supabase-dashboard>

# --- Test workspace (required) ---
# Workspace aislado NO usado en produccion. Crear manualmente:
#   INSERT INTO workspaces (name) VALUES ('TEST — crm-stage-integrity') RETURNING id;
TEST_WORKSPACE_ID=<uuid>

# --- Test pipeline + 3 stages (required para CAS concurrency test) ---
# Seed SQL:
#   INSERT INTO pipelines (workspace_id, name)
#     VALUES ('<TEST_WORKSPACE_ID>', 'Test Pipeline') RETURNING id;
#   INSERT INTO pipeline_stages (pipeline_id, name, position) VALUES
#     ('<TEST_PIPELINE_ID>', 'A', 0),
#     ('<TEST_PIPELINE_ID>', 'B', 1),
#     ('<TEST_PIPELINE_ID>', 'C', 2)
#   RETURNING id;
TEST_PIPELINE_ID=<uuid>
TEST_STAGE_A=<uuid>
TEST_STAGE_B=<uuid>
TEST_STAGE_C=<uuid>
